{
  "name": "utils-axiomate",
  "version": "0.1.0",
  "description": "Common terminal utilities: string width, ANSI slicing/wrapping, terminal detection, semver, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "emoji-regex": "^10.0.0",
    "get-east-asian-width": "^1.0.0",
    "semver": "^7.0.0",
    "strip-ansi": "^7.0.0",
    "supports-hyperlinks": "^3.0.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.0.0",
    "typescript": "^5.5.0"
  }
}
